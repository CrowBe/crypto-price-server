# Pusher application credentials
# Obtain these from your Pusher dashboard: https://dashboard.pusher.com
PUSHER_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_app_key
PUSHER_SECRET=your_pusher_app_secret
PUSHER_CLUSTER=your_pusher_cluster   # e.g. us2, eu, ap2

# Server port (defaults to 5000 if not set)
PORT=5000

# Comma-separated list of allowed CORS origins.
# Restrict this to your frontend domain(s) in production.
# If unset, all origins are permitted (development default).
CORS_ORIGIN=http://localhost:3000
